# 环境变量配置文件示例
# 复制此文件为 .env 并填写实际值

# ==================== 前端配置 ====================

# 应用标题
VITE_APP_TITLE=Nexus

# API 基础地址
VITE_API_BASE_URL=http://localhost:8000

# ==================== 后端配置 ====================

# 数据库连接字符串
DATABASE_URL=sqlite+aiosqlite:///./data/nexus.db

# 调试模式
DEBUG=true

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/nexus.log

# ==================== AI 模型配置 ====================

# 默认模型
DEFAULT_MODEL=gpt-3.5-turbo

# 最大 Token 数
MAX_TOKENS=4096

# 温度参数 (0-2)
TEMPERATURE=0.7

# 向量维度
VECTOR_DIMENSION=1536

# ==================== API 密钥 ====================
# 请勿将实际密钥提交到版本控制

# OpenAI API Key
# OPENAI_API_KEY=sk-xxx

# Anthropic API Key
# ANTHROPIC_API_KEY=sk-ant-xxx
